rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 사운드: 앱은 approved만 읽기, 관리자(로컬)는 전체 읽기/쓰기
    match /sounds/{soundId} {
      allow read: if true;   // 앱 + 관리자 페이지 모두 읽기 가능
      allow write: if true;  // 개발 단계 — 운영 전 인증 추가 필요
    }

    // 관리자 컬렉션
    match /admins/{userId} {
      allow read, write: if false;
    }

    match /upload_logs/{logId} {
      allow read, write: if false;
    }
  }
}
