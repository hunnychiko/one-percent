{
  "rules": {
    "users": {
      "$uid": {
        ".read":  "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        "fcmToken": { ".write": "$uid === auth.uid" }
      }
    },
    "productRooms": {
      ".read": "auth != null",
      ".write": false
    },
    "drawEntries": {
      ".read": "auth != null",
      "$entryId": {
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid)",
        ".validate": "newData.child('userId').val() === auth.uid && newData.child('roomId').isString()"
      }
    },
    "matchQueue": {
      "$roomId": {
        "$streak": {
          "$userId": {
            ".read":  "auth != null",
            ".write": "auth != null && $userId === auth.uid"
          }
        }
      }
    },
    "matches": {
      "$matchId": {
        ".read":  "auth != null && (data.child('player1').val() === auth.uid || data.child('player2').val() === auth.uid)",
        ".write": "auth != null && (data.child('player1').val() === auth.uid || data.child('player2').val() === auth.uid)"
      }
    },
    "winnerClaims": {
      "$claimId": {
        ".read":  "auth != null && data.child('userId').val() === auth.uid",
        ".write": "auth != null && data.child('userId').val() === auth.uid"
      }
    },
    "drawResults": {
      ".read":  "auth != null",
      ".write": false
    },
    "rankings": {
      ".read":  true,
      ".write": false
    },
    "affiliateBanners": {
      ".read":  "auth != null",
      ".write": false
    }
  }
}
